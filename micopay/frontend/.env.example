# Backend REST API (trades, users, DeFi endpoints)
# CONTRIBUTING.md documents the backend on port 3002 when running the full stack.
# The app defaults to 3000 if this variable is unset.
VITE_API_URL=http://localhost:3000

# Protocol API — used by ClaimQR.tsx to poll merchant cash-request status.
# Can point to the same backend or a separate service.
VITE_PROTOCOL_API_URL=http://localhost:3000
